local player = game.Players.LocalPlayer

local function setWalkSpeed(speed)
    local character = player.Character
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.WalkSpeed = speed
    end
end

task.spawn(function()
    while true do
        setWalkSpeed(100)
        task.wait(0.1)
    end
end)
